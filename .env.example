# LoRAForge configuration. Copy to .env and fill in. .env is gitignored.

# --- Serving (serve/main.py) -------------------------------------------------
# API key clients must send as `Authorization: Bearer <key>`. Pick any secret.
LORAFORGE_API_KEY=change-me-to-a-long-random-string

# Where the FastAPI proxy reaches Ollama's OpenAI-compatible endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1

# The fine-tuned model name created via `ollama create` (see serve/Modelfile).
LORAFORGE_MODEL=loraforge-ft

# Server-side system prompt is injected by the proxy and cannot be overridden
# by clients. Override the default here if you want.
# LORAFORGE_SYSTEM_PROMPT=You are a helpful customer-support assistant for Acme.

# --- Training (notebooks/01-finetune.ipynb, scripts/train.py) ----------------
# Hugging Face read token. NOT needed for the default Qwen3 base or the Bitext
# dataset (both are ungated). Only set this if you point training at a gated repo.
# Get one at https://huggingface.co/settings/tokens.
HF_TOKEN=
